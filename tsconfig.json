{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "expo-*": ["./node_modules/expo-*"]
    }
  },
  "include": [
    "App.js",
    "components/**/*",
    "contexts/**/*",
    "navigation/**/*",
    "screens/**/*",
    "services/**/*",
    "utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "ios",
    "android"
  ]
}
